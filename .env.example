GOOGLE_API_KEY=
OPENAI_API_KEY=

# Opcional: modelos
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# BANCO — escolha UM: SQLite (local) OU PostgreSQL (ex.: Neon, gratuito)
# -----------------------------------------------------------------------------
# Se NÃO definir DATABASE_URL, o app usa o arquivo abaixo (padrão:
# Banco SQLite com TODO o histórico de análises; pasta `data/` não entra no Git).
# DB_PATH=C:/Users/SEU_USUARIO/Projeto/Dasboard Performance/data/app.db
DB_PATH=data/app.db

# PostgreSQL (Neon, etc.): string completa "postgresql://usuario:senha@host/banco?sslmode=require"
# Com esta variável preenchida, o app ignora o SQLite e grava tudo no servidor.
# Passo a passo Neon (plano Free — desenvolvimento / volume pequeno):
# 1) Acesse https://console.neon.tech e crie conta (Google/GitHub).
# 2) Crie um Project; escolha região (ex. South America) se o painel oferecer.
# 3) No projeto, abra "Connection" / "Connect" e copie a connection string.
# 4) Cole abaixo (muitas vezes vem com ?sslmode=require — mantenha).
# 5) Não commite a URL (ela contém senha). Use .env local ou Streamlit secrets.
# 6) Free tier: compute pode "dormir" após inatividade; a 1ª conexão após isso leva
#    alguns segundos. Há limites de armazenamento/horas — veja a página de preços do Neon.
# DATABASE_URL=postgresql://neondb_owner:xxxxx@ep-xxx.aws.neon.tech/neondb?sslmode=require

# Onde salvar anexos/prints no disco (sempre local, mesmo com Neon). Padrão: pasta data/
DATA_DIR=data

# Login opcional (se preencher, o app pede login)
ADMIN_USERNAME=
ADMIN_PASSWORD=

